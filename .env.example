# Production backend used by app builds and Expo Go unless explicitly overridden.
EXPO_PUBLIC_API_BASE_URL=https://adustech-backend.vercel.app
EXPO_PUBLIC_API_RESOLUTION_MODE=remote-only

# Optional: force Expo Go on a physical device to use your local backend during development.
# Example: EXPO_PUBLIC_LOCAL_API_BASE_URL=http://192.168.1.20:5000
# EXPO_PUBLIC_LOCAL_API_BASE_URL=
